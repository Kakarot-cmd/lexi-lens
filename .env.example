# ─────────────────────────────────────────────────────────────────────────────
# Lexi-Lens local environment template
#
# How to use:
#   1. Copy this file to .env.local      (already gitignored — safe to put
#                                         secrets there, won't be committed)
#   2. Fill in the values below with credentials from your STAGING Supabase
#   3. Run `npx expo start` — Expo automatically loads .env.local
#
# IMPORTANT: This file controls LOCAL DEVELOPMENT ONLY.
# Local dev ALWAYS points at the STAGING Supabase project (your existing one).
# It never points at PRODUCTION. If you find yourself tempted to add PROD
# credentials here, stop and read docs/ENVIRONMENTS.md again.
#
# For EAS cloud builds, these variables come from EAS Secrets, NOT this file.
# See ENVIRONMENTS.md for the `eas secret:create` commands.
# ─────────────────────────────────────────────────────────────────────────────

# Variant your local Metro server runs as. Leave this as "development".
APP_VARIANT=development
EXPO_PUBLIC_APP_VARIANT=development

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your STAGING Supabase project (the existing one,
# zhnaxafmacygbhpvtwvf — the one you've been using all along):
#   Dashboard → Settings → API → Project URL + anon public key
EXPO_PUBLIC_SUPABASE_URL=https://<your-staging-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Sentry ──────────────────────────────────────────────────────────────────
# Optional in dev. Required for staging + prod EAS builds (set as EAS Secret).
# If you have a single Sentry project, you can use the same DSN here — events
# will be tagged with environment="development" automatically by lib/sentry.ts.
EXPO_PUBLIC_SENTRY_DSN=

# ── RevenueCat (Phase 4.4 — fill in once IAP integration starts) ───────────
# In sandbox/staging, use the test keys from your RevenueCat project's
# "Sandbox" environment. Production uses the real keys.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ── App version (set automatically by EAS, override locally if needed) ──────
EXPO_PUBLIC_APP_VERSION=1.0.12-local
