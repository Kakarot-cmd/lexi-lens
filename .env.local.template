# ─── .env.local.template ─────────────────────────────────────────────────────
#
# COPY THIS FILE to `.env.local` at the repo root and fill in the values.
# `.env.local` is gitignored — never commit real secrets.
#
# Used by: local Android Gradle builds (`scripts\build-android.cmd`) and
# `npx expo start` for local Metro dev sessions. EAS Cloud builds do NOT
# read this file; they use EAS environment variables configured via
# `eas env:list` and mapped through eas.json.
#
# Two sections:
#   1. EAS-parity vars — suffixed (_STAGING/_PROD/_SANDBOX). Documentation
#      only; the code does NOT read these. Kept for parity with EAS env
#      structure so you can switch between staging/prod locally by toggling
#      the unsuffixed values in section 2.
#   2. Code-consumed vars — unsuffixed. THESE are what Metro bundles into
#      the JS and what `process.env.EXPO_PUBLIC_*` reads at runtime.
#
# To switch local builds between staging and prod, edit section 2 only.
#
# Where to find the values:
#   Supabase URL/anon key → https://supabase.com/dashboard/project/<ref>/settings/api
#   Sentry DSN            → https://njlabs.sentry.io/settings/projects/<project>/keys/
#   RC SDK keys           → https://app.revenuecat.com/projects/<project>/apps
#
# Or run:  eas env:list --environment development        (for _STAGING vars)
#          eas env:list --environment production         (for _PROD vars)

# ─── 1. EAS-parity vars (reference / documentation — code does NOT read these) ─

EXPO_PUBLIC_SUPABASE_URL_STAGING=
EXPO_PUBLIC_SUPABASE_URL_PROD=
EXPO_PUBLIC_SUPABASE_ANON_KEY_STAGING=
EXPO_PUBLIC_SUPABASE_ANON_KEY_PROD=
EXPO_PUBLIC_SENTRY_DSN_STAGING=
EXPO_PUBLIC_SENTRY_DSN_PROD=
EXPO_PUBLIC_REVENUECAT_IOS_KEY_SANDBOX=
EXPO_PUBLIC_REVENUECAT_IOS_KEY_PROD=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY_SANDBOX=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY_PROD=

# ─── 2. What the code actually reads (unsuffixed) ────────────────────────────
# Point these at STAGING for local sandbox builds. Toggle to PROD values
# only for production launches (rare from local — usually EAS Cloud builds).

EXPO_PUBLIC_APP_VARIANT=staging
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# RC keys can be empty until RC Dashboard is set up; lib/revenueCat.ts
# gracefully no-ops when keys are missing.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ─── Notes ───────────────────────────────────────────────────────────────────
# - All EXPO_PUBLIC_* values are EMBEDDED into the bundled JS at build time.
#   They are NOT secret. Treat them as public configuration. For real secrets
#   (auth tokens, service-account JSON, keystore passwords), use:
#     - Supabase secrets (server-side):   supabase secrets set NAME=value
#     - EAS env Secret-type vars:         eas env:create ... --visibility sensitive
#     - android/gradle.properties:        gitignored, never committed
# - SENTRY_AUTH_TOKEN is NEVER in .env.local. It's an EAS Secret consumed only
#   by EAS Cloud builds for source-map upload. Local Gradle builds skip
#   source-map upload entirely (build-android.cmd sets SENTRY_DISABLE_AUTO_UPLOAD).
