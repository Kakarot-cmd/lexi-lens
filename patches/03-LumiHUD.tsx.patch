From: Lumi Upgrade v1 (orbit-reticle, larger+faster scan-wait mascot)
Subject: [PATCH 3/4] LumiHUD.tsx — reticleCenter prop + hard-mode orbit allowance

Two additive changes:

  1. Add `reticleCenter?: {x, y}` to LumiHUDProps so callers (ScanScreen) can
     hand a screen-coord center to orbit around. Forwarded to LumiMascot as
     `freePosition` so the existing freePosition plumbing in LumiMascot picks
     it up.

  2. Relax the existing "hard mode forces anchor" override to specifically
     ALLOW 'orbit-reticle'. The red-crown Lumi spinning during a hard quest
     reinforces "this is intense" — it doesn't hide the crown because the
     orbit radius keeps Lumi within the reticle, fully on-screen.

---
 components/Lumi/LumiHUD.tsx | 14 +++++++++++++-
 1 file changed, 13 insertions(+), 1 deletion(-)

diff --git a/components/Lumi/LumiHUD.tsx b/components/Lumi/LumiHUD.tsx
--- a/components/Lumi/LumiHUD.tsx
+++ b/components/Lumi/LumiHUD.tsx
@@ -83,6 +83,11 @@ export interface LumiHUDProps {
   muted?:               boolean;
   hidden?:              boolean;
   zIndex?:              number;
+  /**
+   * v6.5 — when set with movement='orbit-reticle', Lumi orbits this
+   * screen-coord center at the active state's orbitRadius/orbitSpeedRpm.
+   */
+  reticleCenter?:       { x: number; y: number };
 }
 
 export function LumiHUD(props: LumiHUDProps): React.ReactElement | null {
@@ -100,6 +105,7 @@ export function LumiHUD(props: LumiHUDProps): React.ReactElement | null {
     muted             = false,
     hidden            = false,
     zIndex            = 100,
+    reticleCenter,
   } = props;
 
   const preset = SCREEN_PRESETS[screen];
@@ -135,9 +141,13 @@ export function LumiHUD(props: LumiHUDProps): React.ReactElement | null {
     return preset.defaultState;
   }, [dailyLimitReached, transient, evaluationStatus, failureStreak, preset.defaultState]);
 
-  // Hard-mode forces anchor (so kids see the crown clearly without it darting around)
+  // Hard-mode forces anchor for wander/drift (so kids see the crown clearly
+  // without it darting all over the screen). 'orbit-reticle' is exempt — the
+  // orbit stays bounded inside the viewfinder, the crown stays readable, and
+  // a spinning red Lumi reinforces "this quest is intense".
+  const requestedMovement: LumiMovementMode = movement ?? preset.movement;
   const resolvedMovement: LumiMovementMode =
-    hardMode ? 'anchor' : (movement ?? preset.movement);
+    hardMode && requestedMovement !== 'orbit-reticle' ? 'anchor' : requestedMovement;
 
   // Hard-mode also forces non-rainbow (red crown is the brand cue)
   const resolvedRainbow = hardMode ? false : (rainbow ?? preset.rainbow);
@@ -156,6 +166,8 @@ export function LumiHUD(props: LumiHUDProps): React.ReactElement | null {
       rainbow={resolvedRainbow}
       muted={muted}
       zIndex={zIndex}
+      // v6.5 — forwarded to LumiMascot's freePosition for orbit-reticle math.
+      freePosition={reticleCenter}
     />
   );
 }
